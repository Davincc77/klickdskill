          "level": "confirm",
          "reason": "Roadmap commitments to external stakeholders are hard to retract."
        },
        {
          "id": "feature-cut-on-evidence-skip",
          "action_class": "skip_evidence_for_feature_decision",
          "level": "block",
          "reason": "Cutting or pursuing a feature without evidence is blocked; decisions must cite a research artefact."
