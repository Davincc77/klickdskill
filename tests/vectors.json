{
  "spec_version": "2.5",
  "notes": {
    "aad_canonical_form": "AAD is canonical JSON of exactly 4 envelope fields: {klickd_version, encrypted, domain, created_at}. Keys sorted, separators=(',',':'), ensure_ascii=True. NOT 5 fields — the stale '5 fields' comment in earlier versions was a bug.",
    "base64_variant": "RFC 4648 §4 standard padded base64 (no URL-safe substitution)",
    "ciphertext_layout": "base64(AES-GCM ciphertext_bytes || 16-byte GCM tag)",
    "kdf": "PBKDF2-SHA256, 600000 iterations, 32-byte output key",
    "iv_size": "12 bytes (96 bits) — standard AES-GCM nonce",
    "salt_size": "16 bytes"
  },
