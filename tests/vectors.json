{
  "description": ".klickd v2.5 test vectors",
  "spec_version": "2.5",
  "notes": [
    "AAD = json.dumps({klickd_version,encrypted,domain,created_at}, sort_keys=True, separators=(',',':'), ensure_ascii=True)",
    "4 fields in AAD — exactly: created_at, domain, encrypted, klickd_version (sorted)",
    "Wire format: base64(ciphertext || GCM_tag_16_bytes) — RFC 4648 §4 standard padded",
    "Inner JSON: UTF-8, no BOM",
    "payload field renamed from agent_instructions to user_preferences in v2.5"
  ],
  "vectors": [
    {
      "id": "v2.5-basic-ascii",
      "description": "Basic ASCII payload — domain=general, should decrypt successfully",
      "passphrase": "test-klickd-v25",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "general",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "DveP3ddbG+uRUHJ27S6Stw==",
        "iv": "bWhMKdTrcYjV4Gju",
        "ciphertext": ""
      },
      "expected_display_name": "Alice",
      "expected_behavior": "decrypt_success"
    },
    {
      "id": "v2.5-french-utf8",
      "description": "UTF-8 French payload with accented characters — domain=education",
      "passphrase": "motdepasse-test",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "education",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "mspjl7EMNbko2aa6aHpSIQ==",
        "iv": "g5tUNii4NPVM6MYj",
        "ciphertext": ""
      },
      "expected_display_name": "Léa Müller",
      "expected_behavior": "decrypt_success"
    },
    {
      "id": "v2.5-tampered",
      "description": "Last byte of ciphertext XORed — MUST raise KlickdAuthError",
      "passphrase": "test-klickd-v25",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "general",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "DveP3ddbG+uRUHJ27S6Stw==",
        "iv": "bWhMKdTrcYjV4Gju",
        "ciphertext": ""
      },
      "expected_behavior": "KlickdAuthError — tampered ciphertext"
    },
    {
      "id": "v2.5-wrong-passphrase",
      "description": "Correct envelope, wrong passphrase — MUST raise KlickdAuthError",
      "passphrase": "wrong-passphrase",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "general",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "DveP3ddbG+uRUHJ27S6Stw==",
        "iv": "bWhMKdTrcYjV4Gju",
        "ciphertext": ""
      },
      "expected_behavior": "KlickdAuthError — wrong passphrase"
    },
    {
      "id": "v2.5-short-passphrase",
      "description": "6-char passphrase — MUST raise KlickdWeakPassphraseError (Bankr patch: <8 now hard error)",
      "passphrase": "abc123",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "general",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "fZSXDmJPG0+Rpo2uq5HG3A==",
        "iv": "BKwWmIx3qO6JIbsE",
        "ciphertext": ""
      },
      "expected_display_name": "Alice",
      "expected_behavior": "KlickdWeakPassphraseError — KLICKD_E_WEAK_PASS (passphrase < 8 chars)"
    },
    {
      "id": "v2.5-warn-passphrase",
      "description": "8-char passphrase (>= min, < warn threshold 12) — MUST decrypt with stderr warning",
      "passphrase": "pass1234",
      "envelope": {
        "klickd_version": "2.5",
        "encrypted": true,
        "domain": "general",
        "created_at": "2026-05-18T10:00:00Z",
        "kdf_salt": "R6NOnm2tQjP0YhB3bAtQxA==",
        "iv": "b4G/bJQwrl8kBjsN",
        "ciphertext": "Nl1HcaX5bZOLetr5oBDwMEsbFRUa+oT0z366o80VNJRu0FNSYdF+rTrQlTdS1RSjT3uTkhApNjYlgkzxrcNezOUlSJS51lzvyyimvJwCFZDk"
      },
      "expected_display_name": "Alice",
      "expected_behavior": "UserWarning emitted + decrypt_success (passphrase 8 chars: >= min, < 12 recommended)"
    }
  ]
}