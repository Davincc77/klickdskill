        "klickd_version": "3.0",
        "encrypted": true,
        "domain": "test",
        "created_at": "2026-05-18T12:00:00Z",
        "kdf": {
          "name": "argon2id",
          "params": {
            "m": 1,
            "t": 3,
            "p": 1
          },
          "salt": "eAHMXXcaQvvS/enr4kAuAg=="
        },
        "cipher": {
          "name": "aes-256-gcm",
          "iv": "sZmmurTJy87gvOG4"
        },
        "ciphertext": "iQ4bfVufEugSu3fEZz2DbMAg4CVWDq0hKmtD6LPNAVE/xEmYIE6SYb5db8+XYhtsOOYnI/K4253ixbADsQlkFWjIHoXdCamOtg=="
