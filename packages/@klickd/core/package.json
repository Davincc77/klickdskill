{
  "name": "@klickd/core",
  "version": "4.0.2",
  "description": "Official JavaScript/TypeScript library for reading and writing .klickd portable AI context files",
  "keywords": [
    "klickd",
    "ai-context",
    "portable",
    "memory",
    "encrypted"
  ],
  "homepage": "https://klickd.app/klickdskill",
  "repository": {
    "type": "git",
    "url": "https://github.com/Davincc77/klickdskill"
  },
  "license": "CC0-1.0",
  "author": "Vincenzo Cirilli (.klickd) <hello@klickd.app> (https://klickd.app)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "starter-skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external argon2 --external argon2-browser --external ajv",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "verify:tarball": "node scripts/verify-tarball.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "canonicalize": "^2.0.0",
    "hash-wasm": "^4.11.0"
  },
  "peerDependencies": {
    "ajv": "^8.12.0"
  },
  "peerDependenciesMeta": {
    "ajv": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "ajv": "^8.12.0",
    "argon2": "^0.44.0",
    "argon2-browser": "^1.18.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
