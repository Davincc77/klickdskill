      "structural_checks": [
        { "id": "msh-three-sessions", "rule": "sessions array length == 3" },
        { "id": "msh-resume-empty-decisions", "rule": "last session has decisions_made.length == 0 (it is the resume session)" },
        { "id": "msh-minimum-context-nonempty", "rule": "expected_resume_minimum_context.length >= 4" },
        { "id": "msh-forbids-reexplain", "rule": "forbidden_resume_behaviors includes 'ask_lea_to_re_explain_project'" }
      ]
    }
