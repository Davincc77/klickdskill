        { "id": "mvb-no-data-loss", "rule": "expected report has data_loss == false" },
        { "id": "mvb-warns-for-missing-v4-fields", "rule": "expected report warnings include code 'missing_field.handoff' and 'missing_field.verification_artifacts'" }
      ]
    },
    "tool_call_failure_recovery": {
      "fixture_path": "../edge_cases/tool_call_failure_recovery/scenario.json",
      "artifact_path": "../edge_cases/tool_call_failure_recovery/verification_artifact.log",
      "structural_checks": [
        { "id": "tcfr-failed-first-call", "rule": "turns[1].result.status == 'error' AND turns[1].result.error_code == 'transient_error_500'" },
        { "id": "tcfr-artifact-pointer", "rule": "turns[1].result.artifact_path points to a file that exists and contains 'tool_call.result'" },
        { "id": "tcfr-forbids-blind-retry", "rule": "turns[2].forbidden_behaviors includes 'silent_blind_retry'" },
        { "id": "tcfr-forbids-fabrication", "rule": "turns[2].forbidden_behaviors includes 'fabricate_task_list_without_tool_result'" }
