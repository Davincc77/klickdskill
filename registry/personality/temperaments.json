      "seed_traits": [
        { "label": "ambition", "strength": 0.9 },
        { "label": "prudence", "strength": 0.85 },
        { "label": "adaptability", "strength": 0.8 },
        { "label": "scepticism", "strength": 0.75 },
        { "label": "directness", "strength": 0.7 }
      ]
    },
