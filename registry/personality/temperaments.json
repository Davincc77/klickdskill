      "seed_traits": [
        { "label": "curiosity", "strength": 0.95 },
        { "label": "adaptability", "strength": 0.85 },
        { "label": "enthusiasm", "strength": 0.8 },
        { "label": "creativity", "strength": 0.75 },
        { "label": "independence", "strength": 0.7 }
      ]
    }
  ]
