      "seed_traits": [
        { "label": "scepticism", "strength": 0.9 },
        { "label": "directness", "strength": 0.9 },
        { "label": "ambition", "strength": 0.8 },
        { "label": "resilience", "strength": 0.75 },
        { "label": "rigour", "strength": 0.7 }
