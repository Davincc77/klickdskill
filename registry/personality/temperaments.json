        { "label": "creativity", "strength": 0.95 },
        { "label": "curiosity", "strength": 0.85 },
        { "label": "humour", "strength": 0.7 },
        { "label": "enthusiasm", "strength": 0.75 },
        { "label": "adaptability", "strength": 0.7 }
      ]
