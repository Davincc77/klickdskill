        { "label": "integrity", "strength": 0.95 },
        { "label": "prudence", "strength": 0.9 },
        { "label": "rigour", "strength": 0.85 },
        { "label": "loyalty", "strength": 0.8 },
        { "label": "scepticism", "strength": 0.75 }
