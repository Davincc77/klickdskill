{
  "$schema": "https://klickd.app/registry/schemas/temperaments-v1.schema.json",
  "version": "1.0.0",
  "description": "Standard temperament presets for .klickd Soul Personality (§18quater). Each preset bundles a trait profile; agents MAY use as a starting point before evolution shapes the actual personality.",
  "temperaments": [
    {
